    "description": "Site Static Express application generator",
    "homepage": "https://github.com/joellesenne/joellesenne.github.io#readme",
    "bugs": {
        "url": "https://github.com/joellesenne/joellesenne.github.io/issues"
    },
    "repository": {
        "type": "git",
